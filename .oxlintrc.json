{
  // oxlint host config: loads eslint-plugin-aria-a11y via the experimental
  // jsPlugins API (Phase 1 acceptance — see CLAUDE.md, Implementation Plan §5).
  // Built output, not src: oxlint's plugin runtime is plain Node and cannot
  // resolve the extensionless TS imports. Run `pnpm --filter
  // eslint-plugin-aria-a11y build` first, or use `pnpm parity:oxlint`.
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": ["./packages/eslint-plugin/dist/index.js"],
  // Default oxc categories off so the parity harness (scripts/oxlint-parity.mjs)
  // compares Aria diagnostics only, host to host.
  "categories": {
    "correctness": "off"
  },
  "rules": {
    "aria-a11y/aria-hidden-not-focusable": "error",
    "aria-a11y/aria-syntax-normalize": "error",
    "aria-a11y/control-needs-name": [
      "error",
      {
        "componentSemantics": {
          "IconButton": { "role": "button", "nameProp": "label", "source": "declared" },
          "FancySelect": { "role": "combobox", "requiresName": true, "nameProp": "value", "source": "declared" },
          "BareWidget": { "role": "combobox", "source": "declared" }
        }
      }
    ],
    "aria-a11y/idref-resolves": "error",
    "aria-a11y/img-needs-alt": [
      "error",
      {
        "componentSemantics": {
          "MyImage": { "role": "img", "nameProp": "altText", "source": "declared" },
          "Logo": { "role": "img", "source": "declared" }
        }
      }
    ],
    // interactive-role-required's options MUST mirror `ruleOptions` in its
    // fixtures module — the parity harness verifies this and fails on drift.
    // The DeclaredButton entry exists to exercise the config bridge
    // (inferred suggestion vs. declared auto-fix) identically in both hosts.
    "aria-a11y/interactive-role-required": [
      "error",
      { "componentSemantics": { "DeclaredButton": { "role": "button", "source": "declared" } } }
    ],
    "aria-a11y/no-redundant-role": "error",
    "aria-a11y/no-unsupported-aria": "error"
  }
}
